rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email is string;
    }

    function isActiveUser() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.token.email))
        && get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.active == true;
    }

    function isTeacher() {
      return isActiveUser()
        && get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role == "teacher";
    }

    match /lms/courseCatalog {
      allow read: if isActiveUser();
      allow write: if isTeacher();
    }

    match /users/{email} {
      allow read: if signedIn() && (request.auth.token.email == email || isTeacher());
      allow write: if isTeacher();
    }

    match /lms/lessonSchedule {
      allow read: if isActiveUser();
      allow write: if isTeacher();
    }
  }
}
